 104:Core/BSP/multi_button.c **** /**
 105:Core/BSP/multi_button.c ****   * @brief  Check if button is currently pressed
 106:Core/BSP/multi_button.c ****   * @param  handle: the button handle struct
 107:Core/BSP/multi_button.c ****   * @retval 1: pressed, 0: not pressed, -1: error
 108:Core/BSP/multi_button.c ****   */
 109:Core/BSP/multi_button.c **** int button_is_pressed(Button* handle)
 110:Core/BSP/multi_button.c **** {
 111:Core/BSP/multi_button.c **** 	if (!handle) return -1;
 112:Core/BSP/multi_button.c **** 	return (handle->button_level == handle->active_level) ? 1 : 0;
 113:Core/BSP/multi_button.c **** }
 114:Core/BSP/multi_button.c **** 

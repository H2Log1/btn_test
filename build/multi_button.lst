  40:Core/BSP/multi_button.c **** /**
  41:Core/BSP/multi_button.c ****   * @brief  Attach the button event callback function
  42:Core/BSP/multi_button.c ****   * @param  handle: the button handle struct
  43:Core/BSP/multi_button.c ****   * @param  event: trigger event type
  44:Core/BSP/multi_button.c ****   * @param  cb: callback function
  45:Core/BSP/multi_button.c ****   * @param  user_data: user context pointer passed to callback (stored per-button)
  46:Core/BSP/multi_button.c ****   * @retval None
  47:Core/BSP/multi_button.c ****   */
  48:Core/BSP/multi_button.c **** void button_attach(Button* handle, ButtonEvent event, BtnCallback cb, void* user_data)
  49:Core/BSP/multi_button.c **** {
  50:Core/BSP/multi_button.c **** 	if (!handle || event >= BTN_EVENT_COUNT) return;  // parameter validation
  51:Core/BSP/multi_button.c **** 	handle->cb[event] = cb;
  52:Core/BSP/multi_button.c **** 	handle->user_data = user_data;
  53:Core/BSP/multi_button.c **** }
  54:Core/BSP/multi_button.c **** 
  55:Core/BSP/multi_button.c **** /**
  56:Core/BSP/multi_button.c ****   * @brief  Detach the button event callback function
  57:Core/BSP/multi_button.c ****   * @param  handle: the button handle struct
  58:Core/BSP/multi_button.c ****   * @param  event: trigger event type
  59:Core/BSP/multi_button.c ****   * @retval None
  60:Core/BSP/multi_button.c ****   */
  61:Core/BSP/multi_button.c **** void button_detach(Button* handle, ButtonEvent event)
  62:Core/BSP/multi_button.c **** {
  63:Core/BSP/multi_button.c **** 	if (!handle || event >= BTN_EVENT_COUNT) return;  // parameter validation
  64:Core/BSP/multi_button.c **** 	handle->cb[event] = NULL;
  65:Core/BSP/multi_button.c **** }
  66:Core/BSP/multi_button.c **** 
  67:Core/BSP/multi_button.c **** /**
  68:Core/BSP/multi_button.c ****   * @brief  Get the button event that happened
  69:Core/BSP/multi_button.c ****   * @param  handle: the button handle struct
  70:Core/BSP/multi_button.c ****   * @retval button event
  71:Core/BSP/multi_button.c ****   */
  72:Core/BSP/multi_button.c **** ButtonEvent button_get_event(Button* handle)
  73:Core/BSP/multi_button.c **** {
  74:Core/BSP/multi_button.c **** 	if (!handle) return BTN_NONE_PRESS;
  75:Core/BSP/multi_button.c **** 	return (ButtonEvent)(handle->event);
  76:Core/BSP/multi_button.c **** }
  77:Core/BSP/multi_button.c **** 
  78:Core/BSP/multi_button.c **** /**
  79:Core/BSP/multi_button.c ****   * @brief  Get the repeat count of button presses
  80:Core/BSP/multi_button.c ****   * @param  handle: the button handle struct
  81:Core/BSP/multi_button.c ****   * @retval repeat count

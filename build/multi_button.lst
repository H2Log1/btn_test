  25:Core/BSP/multi_button.c ****   */
  26:Core/BSP/multi_button.c **** void button_init(Button* handle, uint8_t(*pin_level)(uint8_t), uint8_t active_level, uint8_t button
  27:Core/BSP/multi_button.c **** {
  28:Core/BSP/multi_button.c **** 	if (!handle || !pin_level) return;  // parameter validation
  29:Core/BSP/multi_button.c **** 
  30:Core/BSP/multi_button.c **** 	memset(handle, 0, sizeof(Button));

  89:Core/BSP/multi_button.c **** /**
  90:Core/BSP/multi_button.c ****   * @brief  Reset button state to idle
  91:Core/BSP/multi_button.c ****   * @param  handle: the button handle struct
  92:Core/BSP/multi_button.c ****   * @retval None
  93:Core/BSP/multi_button.c ****   */
  94:Core/BSP/multi_button.c **** void button_reset(Button* handle)
  95:Core/BSP/multi_button.c **** {
  96:Core/BSP/multi_button.c **** 	if (!handle) return;
  97:Core/BSP/multi_button.c **** 	handle->state = BTN_STATE_IDLE;
  98:Core/BSP/multi_button.c **** 	handle->ticks = 0;
  99:Core/BSP/multi_button.c **** 	handle->repeat = 0;
 100:Core/BSP/multi_button.c **** 	handle->event = (uint8_t)BTN_NONE_PRESS;
 101:Core/BSP/multi_button.c **** 	handle->debounce_cnt = 0;
 102:Core/BSP/multi_button.c **** }

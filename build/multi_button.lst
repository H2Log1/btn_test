  83:Core/BSP/multi_button.c **** uint8_t button_get_repeat_count(Button* handle)
  84:Core/BSP/multi_button.c **** {
  85:Core/BSP/multi_button.c **** 	if (!handle) return 0;
  86:Core/BSP/multi_button.c **** 	return handle->repeat;
